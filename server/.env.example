MUAPI_KEY=your_api_key_here

# --- Model Selection & Cost Optimisation Options ---
# Set SKIP_SEEDANCE=True to skip the expensive Seedance video generation model and call Kling directly.
SKIP_SEEDANCE=False

# Model endpoints on MuAPI. Override these if you want to use cheaper alternative endpoints.
# For example, to save cost, set KLING_MODEL=kling-v2.1-standard-i2v
KLING_MODEL=kling-v2.1-master-i2v
SEEDANCE_MODEL=seedance-2-vip-image-to-video
PORTRAIT_MODEL=bytedance-seedream-v4.5
FRAME_MODEL=nano-banana-2-edit
LLM_MODEL=claude-sonnet-4-6
